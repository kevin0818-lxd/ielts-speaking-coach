# IELTS Speaking Coach - Environment Variables
# Copy this file to .env and fill in your values.

# DeepSeek API key (used as LLM fallback when no local model is available)
DEEPSEEK_API_KEY=

# Local fine-tuned model path (leave empty to use DeepSeek API only)
LOCAL_MODEL_PATH=
LOCAL_ENABLE_REASONING=0

# Ontology-driven learning trajectory (set to 1 to enable)
ONTOLOGY_TRAJECTORY_ENABLED=0
TRAJECTORY_DB_PATH=backend/data/learner_trajectory.db
