# IELTS Speaking Coach - Backend Environment Variables
# These variables are ONLY used by the optional self-hosted backend (backend/ directory).
# They are NOT used by the OpenClaw skill itself.
# Copy this file to .env and fill in your values.

# === LLM Configuration ===
# DeepSeek API key (used as LLM fallback when no local model is available)
DEEPSEEK_API_KEY=

# Local fine-tuned model path (leave empty to use DeepSeek API only)
LOCAL_MODEL_PATH=
# Enable reasoning mode for local model (0=disabled, 1=enabled)
LOCAL_ENABLE_REASONING=0

# === Learning Trajectory ===
# Ontology-driven learning trajectory (set to 1 to enable)
ONTOLOGY_TRAJECTORY_ENABLED=0
# SQLite database path for learner trajectory persistence
TRAJECTORY_DB_PATH=backend/data/learner_trajectory.db

# === Audio Feature Extraction ===
# Path to pre-computed base corpus statistics (for feature normalization)
BASE_STATS_PATH=
# Directory containing training audio data (for base_build_stats.py)
DATA_PATH=
# HuggingFace SSL model name for audio feature extraction
SSL_MODEL_NAME=facebook/wav2vec2-base
# Local cache directory for SSL model weights
SSL_CACHE_DIR=
